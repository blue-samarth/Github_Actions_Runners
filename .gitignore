# Terraform
# Ignore Terraform state files, crash logs, and directories that contain
# sensitive or machine-specific data.

# Local .terraform directories
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*
# State backup files
*.tfstate.backup

# Crash log
crash.log

# Terraform plan output
*.tfplan

# Ignore override files generated by the CLI
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files with sensitive data
terraform.rc
terraform.rc.json

# Sensitive variable files (uncomment if you commit tfvars separately)
# These often contain secrets and should generally be ignored
*.tfvars
*.tfvars.json

# Local environment files
.terraformrc

# Ignore CLI-generated files used for caching or local runs
.terraform.lock.*

# Keep the lockfile tracked when present (allow .terraform.lock.hcl)
!/.terraform.lock.hcl

# Editor and OS files
.DS_Store
.vscode/
*.swp
*~

# GitHub Actions runner caches and workspace files (if any)
# Recommended to ignore runner work directories if present
# .runner-work/
*lock*
*.pem

# Local-only helper scripts (kept out of the repo; may contain account-specific values)
establish_local_connection.sh
validate_script.sh
wtf.sh